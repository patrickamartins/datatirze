<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Google Tag Manager -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TRRDTHW4');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DataTirze</title>
  <link rel="stylesheet" href="/style.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TRRDTHW4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
  <!-- End Google Tag Manager (noscript) -->


  <div class="card filters-card">
  <h2>Filtros</h2>
  <div class="filters-grid">
    ...
  </div>
</div>

  <div class="container">
    <div class="header">
      <div class="brand">
        <img src="/images/logo-datatirze.png" alt="DataTirze" class="logo" />
        <h1></h1>
      </div>
      <a href="/" class="btn btn-secondary">Voltar ao Formulário</a>
    </div>

    <div class="grid-dashboard">
      <div class="card">
        <h2>Aceitação por produto e sexo</h2>
        <canvas id="chartAcceptance"></canvas>
      </div>

      <div class="card">
        <h2>Sintomas mais comuns</h2>
        <canvas id="chartSymptoms"></canvas>
      </div>

      <div class="card full">
        <h2>Lotes com mais sintomas negativos</h2>
        <canvas id="chartLots"></canvas>
      </div>

      <div class="card full">
        <h2>Registros enviados</h2>
        <div class="table-wrapper">
          <table id="reportsTable">
            <thead>
              <tr>
                <th>Sexo</th>
                <th>Produto</th>
                <th>Lote</th>
                <th>Dose</th>
                <th>Sintomas</th>
                <th>Observações</th>
                <th>Data</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    let chartAcceptanceInstance = null;
    let chartSymptomsInstance = null;
    let chartLotsInstance = null;

    async function loadDashboard() {
      const response = await fetch("/api/dashboard");
      const data = await response.json();

      if (chartAcceptanceInstance) chartAcceptanceInstance.destroy();
      if (chartSymptomsInstance) chartSymptomsInstance.destroy();
      if (chartLotsInstance) chartLotsInstance.destroy();

      const acceptanceLabels = data.acceptance.map(
        item => `${item.produto} - ${item.sexo}`
      );
      const acceptanceValues = data.acceptance.map(
        item => item.aceitacaoPercentual
      );

      chartAcceptanceInstance = new Chart(document.getElementById("chartAcceptance"), {
        type: "bar",
        data: {
          labels: acceptanceLabels,
          datasets: [{
            label: "% de aceitação",
            data: acceptanceValues
          }]
        },
        options: {
          responsive: true,
          scales: {
            y: {
              beginAtZero: true,
              max: 100
            }
          }
        }
      });

      const symptomLabels = data.sintomasComuns.map(item => item.sintoma);
      const symptomValues = data.sintomasComuns.map(item => item.total);

      chartSymptomsInstance = new Chart(document.getElementById("chartSymptoms"), {
        type: "pie",
        data: {
          labels: symptomLabels,
          datasets: [{
            label: "Quantidade",
            data: symptomValues
          }]
        },
        options: {
          responsive: true
        }
      });

      const lotLabels = data.lotesNegativos.map(
        item => `${item.produto} - Lote ${item.lote}`
      );
      const lotValues = data.lotesNegativos.map(
        item => item.totalNegativos
      );

      chartLotsInstance = new Chart(document.getElementById("chartLots"), {
        type: "bar",
        data: {
          labels: lotLabels,
          datasets: [{
            label: "Relatos negativos",
            data: lotValues
          }]
        },
        options: {
          responsive: true,
          indexAxis: "y"
        }
      });

      const tbody = document.querySelector("#reportsTable tbody");
      tbody.innerHTML = "";

      data.tabela.forEach(item => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td>${item.sexo}</td>
          <td>${item.produto}</td>
          <td>${item.lote}</td>
          <td>${item.dose ?? ""}</td>
          <td>${item.sintomas}</td>
          <td>${item.observacoes || ""}</td>
          <td>${new Date(item.created_at).toLocaleString("pt-BR")}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    loadDashboard();
  </script>
</body>
</html>