<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Google Tag Manager -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TRRDTHW4');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DataTirze</title>
  <link rel="stylesheet" href="/style.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TRRDTHW4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
  <!-- End Google Tag Manager (noscript) -->

  <div class="container">
    <div class="header dashboard-header">
      <div class="brand">
        <img src="/images/logo-datatirze.png" alt="DataTirze" class="logo" />
      </div>

      <div class="header-actions">
        <a href="/" class="btn btn-secondary">Voltar ao Formulário</a>
      </div>
    </div>

    <div class="card filters-card">
      <h2>Filtros</h2>
      <div class="filters-grid">
        <div>
          <label for="filtroProduto">Marca / Produto</label>
          <select id="filtroProduto">
            <option value="">Todos</option>
            <% produtos.forEach(produto => { %>
              <option value="<%= produto %>"><%= produto %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label for="filtroDose">Dosagem</label>
          <select id="filtroDose">
            <option value="">Todas</option>
          </select>
        </div>

        <div>
          <label for="filtroSexo">Gênero</label>
          <select id="filtroSexo">
            <option value="">Todos</option>
          </select>
        </div>

        <div class="filter-actions">
          <button id="btnLimpar" class="btn" type="button">Limpar filtros</button>
        </div>
      </div>
    </div>

    <div class="grid-dashboard">
      <div class="card">
        <h2>Aceitação por produto e sexo</h2>
        <div class="chart-box">
          <canvas id="chartAcceptance"></canvas>
        </div>
      </div>

      <div class="card">
        <h2>Sintomas mais comuns</h2>
        <div class="chart-box chart-box-pie">
          <canvas id="chartSymptoms"></canvas>
        </div>
      </div>

      <div class="card">
        <h2>Faixa etária</h2>
        <div class="chart-box">
          <canvas id="chartAge"></canvas>
        </div>
      </div>

      <div class="card full">
        <h2>Lotes com mais sintomas negativos</h2>
        <div class="chart-box chart-box-horizontal">
          <canvas id="chartLots"></canvas>
        </div>
      </div>

      <div class="card full">
        <h2>Registros enviados</h2>
        <div class="table-wrapper">
          <table id="reportsTable">
            <thead>
              <tr>
                <th>Sexo</th>
                <th>Idade</th>
                <th>Faixa etária</th>
                <th>Produto</th>
                <th>Lote</th>
                <th>Dose</th>
                <th>Local da compra</th>
                <th>Sintomas</th>
                <th>Observações</th>
                <th>Data</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    let chartAcceptanceInstance = null;
    let chartSymptomsInstance = null;
    let chartLotsInstance = null;
    let chartAgeInstance = null;

    async function loadDashboard() {
      const produto = document.getElementById("filtroProduto").value;
      const dose = document.getElementById("filtroDose").value;
      const sexo = document.getElementById("filtroSexo").value;

      const params = new URLSearchParams();
      if (produto) params.append("produto", produto);
      if (dose) params.append("dose", dose);
      if (sexo) params.append("sexo", sexo);

      const response = await fetch(`/api/dashboard?${params.toString()}`);
      const data = await response.json();

      preencherFiltros(data.filtros);
      renderCharts(data);
      renderTabela(data.tabela);
    }

    function preencherFiltros(filtros) {
      const doseSelect = document.getElementById("filtroDose");
      const sexoSelect = document.getElementById("filtroSexo");

      const doseAtual = doseSelect.value;
      const sexoAtual = sexoSelect.value;

      doseSelect.innerHTML = '<option value="">Todas</option>';
      filtros.doses.forEach((dose) => {
        const option = document.createElement("option");
        option.value = dose;
        option.textContent = dose;
        if (String(dose) === String(doseAtual)) option.selected = true;
        doseSelect.appendChild(option);
      });

      sexoSelect.innerHTML = '<option value="">Todos</option>';
      filtros.sexos.forEach((sexo) => {
        const option = document.createElement("option");
        option.value = sexo;
        option.textContent = sexo;
        if (String(sexo) === String(sexoAtual)) option.selected = true;
        sexoSelect.appendChild(option);
      });
    }

    function destroyCharts() {
      if (chartAcceptanceInstance) chartAcceptanceInstance.destroy();
      if (chartSymptomsInstance) chartSymptomsInstance.destroy();
      if (chartLotsInstance) chartLotsInstance.destroy();
      if (chartAgeInstance) chartAgeInstance.destroy();
    }

    function baseOptions() {
      return {
        responsive: true,
        maintainAspectRatio: false
      };
    }

    function renderCharts(data) {
      destroyCharts();

      const acceptanceLabels = data.acceptance.map(
        item => `${item.produto} - ${item.sexo}`
      );
      const acceptanceValues = data.acceptance.map(
        item => item.aceitacaoPercentual
      );

      chartAcceptanceInstance = new Chart(document.getElementById("chartAcceptance"), {
        type: "bar",
        data: {
          labels: acceptanceLabels,
          datasets: [{
            label: "% de aceitação",
            data: acceptanceValues
          }]
        },
        options: {
          ...baseOptions(),
          scales: {
            y: {
              beginAtZero: true,
              max: 100
            }
          }
        }
      });

      const symptomLabels = data.sintomasComuns.map(item => item.sintoma);
      const symptomValues = data.sintomasComuns.map(item => item.total);

      chartSymptomsInstance = new Chart(document.getElementById("chartSymptoms"), {
        type: "pie",
        data: {
          labels: symptomLabels,
          datasets: [{
            label: "Quantidade",
            data: symptomValues
          }]
        },
        options: {
          ...baseOptions()
        }
      });

      const ageLabels = data.faixasEtarias.map(item => item.faixa);
      const ageValues = data.faixasEtarias.map(item => item.total);

      chartAgeInstance = new Chart(document.getElementById("chartAge"), {
        type: "bar",
        data: {
          labels: ageLabels,
          datasets: [{
            label: "Quantidade de relatos",
            data: ageValues
          }]
        },
        options: {
          ...baseOptions(),
          scales: {
            y: {
              beginAtZero: true
            }
          }
        }
      });

      const lotLabels = data.lotesNegativos.map(
        item => `${item.produto} - Lote ${item.lote}`
      );
      const lotValues = data.lotesNegativos.map(
        item => item.totalNegativos
      );

      chartLotsInstance = new Chart(document.getElementById("chartLots"), {
        type: "bar",
        data: {
          labels: lotLabels,
          datasets: [{
            label: "Relatos negativos",
            data: lotValues
          }]
        },
        options: {
          ...baseOptions(),
          indexAxis: "y"
        }
      });
    }

    function renderTabela(tabela) {
      const tbody = document.querySelector("#reportsTable tbody");
      tbody.innerHTML = "";

      tabela.forEach(item => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td>${item.sexo}</td>
          <td>${item.idade ?? ""}</td>
          <td>${item.faixaEtaria ?? ""}</td>
          <td>${item.produto}</td>
          <td>${item.lote}</td>
          <td>${item.dose ?? ""}</td>
          <td>${item.local_compra ?? ""}</td>
          <td>${item.sintomas}</td>
          <td>${item.observacoes || ""}</td>
          <td>${new Date(item.created_at).toLocaleString("pt-BR")}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function aplicarFiltrosAutomaticamente() {
      document.getElementById("filtroProduto").addEventListener("change", loadDashboard);
      document.getElementById("filtroDose").addEventListener("change", loadDashboard);
      document.getElementById("filtroSexo").addEventListener("change", loadDashboard);
    }

    document.getElementById("btnLimpar").addEventListener("click", () => {
      document.getElementById("filtroProduto").value = "";
      document.getElementById("filtroDose").value = "";
      document.getElementById("filtroSexo").value = "";
      loadDashboard();
    });

    aplicarFiltrosAutomaticamente();
    loadDashboard();
  </script>
</body>
</html>