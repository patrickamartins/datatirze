<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Google Tag Manager -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TRRDTHW4');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DataTirze</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TRRDTHW4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
  <!-- End Google Tag Manager (noscript) -->

  <div class="container">
    <%- include("partials/header") %>

    <% if (success) { %>
      <div class="alert success"><%= success %></div>
    <% } %>

    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <form action="/submit" method="POST" enctype="multipart/form-data" class="card form-grid">
      <div>
        <label>Nome *</label>
        <input type="text" name="nome" required value="<%= formData.nome || '' %>" />
      </div>

      <div>
        <label>Email *</label>
        <input type="email" name="email" required value="<%= formData.email || '' %>" />
      </div>

      <div>
        <label>Telefone *</label>
        <input type="text" name="telefone" required value="<%= formData.telefone || '' %>" />
      </div>

      <div>
        <label>Sexo *</label>
        <select name="sexo" required>
          <option value="">Selecione</option>
          <option value="Masculino" <%= formData.sexo === 'Masculino' ? 'selected' : '' %>>Masculino</option>
          <option value="Feminino" <%= formData.sexo === 'Feminino' ? 'selected' : '' %>>Feminino</option>
          <option value="Outro" <%= formData.sexo === 'Outro' ? 'selected' : '' %>>Outro</option>
          <option value="Prefiro não informar" <%= formData.sexo === 'Prefiro não informar' ? 'selected' : '' %>>Prefiro não informar</option>
        </select>
      </div>

      <div>
        <label>Idade *</label>
        <input type="number" name="idade" min="14" required value="<%= formData.idade || '' %>" />
      </div>

      <div>
        <label>Qual produto? *</label>
        <select name="produto" id="field-produto" required>
          <option value="">Selecione</option>
          <% produtosGrupos.forEach(grupo => { %>
            <optgroup label="<%= grupo.label %>">
              <% grupo.itens.forEach(produto => { %>
                <option value="<%= produto %>" <%= formData.produto === produto ? 'selected' : '' %>><%= produto %></option>
              <% }) %>
            </optgroup>
          <% }) %>
        </select>
      </div>

      <div>
        <label>Qual lote do produto? *</label>
        <input type="number" name="lote" required value="<%= formData.lote || '' %>" />
      </div>

      <div>
        <label>Qual dose utilizada?</label>
        <select name="dose">
          <option value="">Selecione</option>
          <% doses.forEach(dose => { %>
            <option value="<%= dose %>" <%= formData.dose === dose ? 'selected' : '' %>><%= dose %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label>Local onde comprou *</label>
        <select name="local_compra" required>
          <option value="">Selecione</option>
          <% locaisCompra.forEach(local => { %>
            <option value="<%= local %>" <%= formData.local_compra === local ? 'selected' : '' %>><%= local %></option>
          <% }) %>
        </select>
      </div>

      <div class="full">
        <label class="label-with-help">
          <span>Foto do lote da ampola *</span>
          <span class="help-tooltip">
            ?
            <span class="help-tooltip-content">
              <img src="/images/exemplo-lote.png" alt="Exemplo de foto do lote" class="help-example-image" />
              <span class="help-tooltip-text">Envie uma foto nítida mostrando o lote impresso na ampola ou embalagem.</span>
            </span>
          </span>
        </label>
        <input type="file" name="foto_lote" accept="image/*" required />
      </div>

      <div class="full">
        <label>Quais sintomas?</label>
        <p class="form-hint" id="sintomas-categoria-hint">Selecione o produto acima para ver os sintomas específicos desta categoria.</p>
        <div class="checkbox-grid" id="sintomas-container" aria-live="polite"></div>
      </div>

      <div class="full">
        <label>Observações</label>
        <textarea name="observacoes" rows="5"><%= formData.observacoes || '' %></textarea>
      </div>

      <div class="full consent-box">
        <label class="checkbox-item consent-item">
          <input
            type="checkbox"
            name="aceite_termos"
            value="sim"
            required
            <%= formData.aceite_termos ? 'checked' : '' %>
          />
          <span>
            Li e aceito os
            <a href="/termos" target="_blank" rel="noopener noreferrer">Termos e Condições</a>.
          </span>
        </label>

        <label class="checkbox-item consent-item">
          <input
            type="checkbox"
            name="aceite_privacidade"
            value="sim"
            required
            <%= formData.aceite_privacidade ? 'checked' : '' %>
          />
          <span>
            Li e aceito a
            <a href="/privacidade" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>.
          </span>
        </label>
      </div>

      <div class="full">
        <button type="submit" class="btn">Enviar</button>
      </div>
    </form>
  </div>
  <%- include("partials/footer") %>
  <script type="application/json" id="sintomas-por-categoria-data"><%- sintomasPorCategoriaJson %></script>
  <script type="application/json" id="produto-categoria-data"><%- produtoCategoriaJson %></script>
  <script type="application/json" id="form-sintomas-selecionados"><%- JSON.stringify(formData.sintomas || []) %></script>
  <script>
    (function () {
      var elCat = document.getElementById("sintomas-por-categoria-data");
      var elMap = document.getElementById("produto-categoria-data");
      var elSaved = document.getElementById("form-sintomas-selecionados");
      var sintomasPorCategoria = JSON.parse(elCat.textContent || "{}");
      var produtoCategoria = JSON.parse(elMap.textContent || "{}");
      var saved = JSON.parse(elSaved.textContent || "[]");
      var select = document.getElementById("field-produto");
      var container = document.getElementById("sintomas-container");
      var hint = document.getElementById("sintomas-categoria-hint");

      var labels = {
        tirzepatida: "Sintomas frequentes com Tirzepatida (Mounjaro / Zepbound), agonista GIP/GLP-1:",
        retatrutida: "Sintomas frequentes com Retatrutida (tri-agonista GIP/GLP-1/Glucagon):",
        peptideos: "Sintomas frequentes com peptídeos (via subcutânea):"
      };

      function renderSintomas() {
        var produto = select.value;
        var cat = produtoCategoria[produto];
        container.innerHTML = "";
        if (!produto || !cat || !sintomasPorCategoria[cat]) {
          hint.textContent = "Selecione o produto acima para ver os sintomas específicos desta categoria.";
          hint.hidden = false;
          return;
        }
        hint.textContent = labels[cat] || "Marque o que se aplica:";
        hint.hidden = false;
        var list = sintomasPorCategoria[cat];
        list.forEach(function (sintoma) {
          var id = "sintoma-" + sintoma.replace(/[^a-zA-Z0-9]/g, "_").slice(0, 80);
          var label = document.createElement("label");
          label.className = "checkbox-item";
          var input = document.createElement("input");
          input.type = "checkbox";
          input.name = "sintomas";
          input.value = sintoma;
          input.id = id;
          if (saved.indexOf(sintoma) !== -1) input.checked = true;
          var span = document.createElement("span");
          span.textContent = sintoma;
          label.appendChild(input);
          label.appendChild(span);
          container.appendChild(label);
        });
      }

      select.addEventListener("change", function () {
        saved = [];
        renderSintomas();
      });

      container.addEventListener("change", function () {
        saved = Array.prototype.slice.call(container.querySelectorAll('input[name="sintomas"]:checked')).map(function (i) {
          return i.value;
        });
      });

      renderSintomas();
    })();
  </script>
</body>
</html>