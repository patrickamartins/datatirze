<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Google Tag Manager -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TRRDTHW4');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DataTirze - Metabolizando Dados em Inteligência</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TRRDTHW4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
  <!-- End Google Tag Manager (noscript) -->

  <div class="container">
    <div class="header">
  <div class="brand">
    <img src="/images/logo-datatirze.png" alt="DataTirze" class="logo" />
  </div>
  <div class="header-actions">
    <a href="/dashboard" class="btn btn-secondary">Ver Dashboard</a>
  </div>
</div>

    <% if (success) { %>
      <div class="alert success"><%= success %></div>
    <% } %>

    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <form action="/submit" method="POST" enctype="multipart/form-data" class="card form-grid">
      <div>
        <label>Nome *</label>
        <input type="text" name="nome" required value="<%= formData.nome || '' %>" />
      </div>

      <div>
        <label>Email *</label>
        <input type="email" name="email" required value="<%= formData.email || '' %>" />
      </div>

      <div>
        <label>Telefone *</label>
        <input type="text" name="telefone" required value="<%= formData.telefone || '' %>" />
      </div>

      <div>
        <label>Sexo *</label>
        <select name="sexo" required>
          <option value="">Selecione</option>
          <option value="Masculino" <%= formData.sexo === 'Masculino' ? 'selected' : '' %>>Masculino</option>
          <option value="Feminino" <%= formData.sexo === 'Feminino' ? 'selected' : '' %>>Feminino</option>
          <option value="Outro" <%= formData.sexo === 'Outro' ? 'selected' : '' %>>Outro</option>
          <option value="Prefiro não informar" <%= formData.sexo === 'Prefiro não informar' ? 'selected' : '' %>>Prefiro não informar</option>
        </select>
      </div>

      <div>
        <label>Idade *</label>
        <input type="number" name="idade" min="14" required value="<%= formData.idade || '' %>" />
      </div>

      <div>
        <label>Qual produto? *</label>
        <select name="produto" required>
          <option value="">Selecione</option>
          <% produtos.forEach(produto => { %>
            <option value="<%= produto %>" <%= formData.produto === produto ? 'selected' : '' %>>
              <%= produto %>
            </option>
          <% }) %>
        </select>
      </div>

      <div>
        <label>Qual lote do produto? *</label>
        <input type="number" name="lote" required value="<%= formData.lote || '' %>" />
      </div>

      <div>
        <label>Qual dose utilizada?</label>
        <select name="dose">
          <option value="">Selecione</option>
          <% doses.forEach(dose => { %>
            <option value="<%= dose %>" <%= formData.dose === dose ? 'selected' : '' %>>
              <%= dose %>
            </option>
          <% }) %>
        </select>
      </div>

      <div>
        <label>Local onde comprou *</label>
        <select name="local_compra" required>
          <option value="">Selecione</option>
          <% locaisCompra.forEach(local => { %>
            <option value="<%= local %>" <%= formData.local_compra === local ? 'selected' : '' %>>
              <%= local %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="full">
        <label class="label-with-help">
          <span>Foto do lote da ampola *</span>
          <span class="help-tooltip">
            ?
            <span class="help-tooltip-content">
              <img src="/images/exemplo-lote.png" alt="Exemplo de foto do lote" class="help-example-image" />
              <span class="help-tooltip-text">Envie uma foto nítida mostrando o lote impresso na ampola ou embalagem.</span>
            </span>
          </span>
        </label>
        <input type="file" name="foto_lote" accept="image/*" required />
      </div>

      <div class="full">
        <label>Quais sintomas?</label>
        <div class="checkbox-grid">
          <% sintomas.forEach(sintoma => { %>
            <label class="checkbox-item">
              <input
                type="checkbox"
                name="sintomas"
                value="<%= sintoma %>"
                <%= formData.sintomas && formData.sintomas.includes(sintoma) ? 'checked' : '' %>
              />
              <span><%= sintoma %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="full">
        <label>Observações</label>
        <textarea name="observacoes" rows="5"><%= formData.observacoes || '' %></textarea>
      </div>

<div class="full consent-box">
  <label class="checkbox-item consent-item">
    <input
      type="checkbox"
      name="aceite_termos"
      value="sim"
      required
      <%= formData.aceite_termos ? 'checked' : '' %>
    />
    <span>
      Li e aceito os
      <a href="/termos" target="_blank" rel="noopener noreferrer">Termos e Condições</a>.
    </span>
  </label>

  <label class="checkbox-item consent-item">
    <input
      type="checkbox"
      name="aceite_privacidade"
      value="sim"
      required
      <%= formData.aceite_privacidade ? 'checked' : '' %>
    />
    <span>
      Li e aceito a
      <a href="/privacidade" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>.
    </span>
  </label>
</div>

      <div class="full">
        <button type="submit" class="btn">Enviar</button>
      </div>
    </form>
  </div>
</body>
</html>